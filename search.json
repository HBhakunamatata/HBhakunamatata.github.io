---
layout: none
---
[
  {% for post in site.posts %}
    {% capture categories_str %}{% if post.categories.size > 0 %}<i class=\"bi bi-card-list pe-1\"></i><ul class=\"list-inline\">{% for category in post.categories %}<li class=\"list-inline-item badge text-bg-secondary\"><a class=\"text-decoration-none color-light link-light\" href=\"{{ site.baseurl }}/categories/#{{ category | slugify }}\">{{ category }}</a></li>{% endfor %}</ul>{% endif %}{% endcapture %}

    {% capture tags_str %}{% if post.tags.size > 0 %}<i class=\"bi bi-tags-fill pe-1\"></i><ul class=\"list-inline\">{% for tag in post.tags %}<li class=\"list-inline-item badge rounded-pill text-bg-secondary\"><a class=\"text-decoration-none color-light link-light\" href=\"{{ site.baseurl }}/tags/#{{ tag | slugify }}\">{{ tag }}</a></li>{% endfor %}</ul>{% endif %}{% endcapture %}
    {
      "title"    : "{{ post.title | escape }}",
      "categories" : "{{ categories_str }}",
      "tags"     : " {{ tags_str }}",
      "url"      : "{{ post.url | relative_url }}",
      "date"     : "{{ post.date | date: '%Y-%m-%d' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
