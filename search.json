---
layout: none
---
[
  {% for post in site.posts %}
    {% capture categories_str %}{% for category in post.categories %}<li class=\"list-inline-item badge text-bg-secondary\">{{ category }}</li>{% endfor %}{% endcapture %}
    {% capture tags_str %}{% for tag in post.tags %}<li class=\"list-inline-item badge rounded-pill text-bg-secondary\">{{ tag }}</li>{% endfor %}{% endcapture %}
    {
      "title"    : "{{ post.title | escape }}",
      "categories" : "{{ categories_str }}",
      "tags"     : "{{ tags_str }}",
      "url"      : "{{ post.url | relative_url }}",
      "date"     : "{{ post.date | date: '%Y-%m-%d' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
